# Server Port
PORT=5005

# Proxmox VE Configuration
# Set to false to connect to your real Proxmox server
DEMO_MODE=true

# Enter your Proxmox API URL (without trailing slash)
# Example: https://192.168.1.100:8006/api2/json
PROXMOX_API_URL=https://YOUR_PROXMOX_IP:8006/api2/json

# Token ID and Secret created in Proxmox VE
PROXMOX_TOKEN_ID=root@pam!dashboard
PROXMOX_TOKEN_SECRET=your-uuid-token-secret-here

# Bypass Proxmox self-signed SSL verification (0 = ignore/bypass, 1 = strict verification)
NODE_TLS_REJECT_UNAUTHORIZED=0

# Web Dashboard Login Credentials (change these!)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin123
